# Model gateway — leave unset to use the built-in mock provider (no network calls).
# Set to enable the real Claude provider through the gateway.
ANTHROPIC_API_KEY=

# Default reasoning model routed by the gateway (Anthropic-First).
ASTRA_DEFAULT_MODEL=claude-opus-4-8

# Per-campaign token budget enforced by the gateway (0 = unlimited).
ASTRA_CAMPAIGN_TOKEN_BUDGET=200000

# Where the local event store persists (used by the demo/server).
ASTRA_DATA_DIR=.data

# Production Postgres connection string. Leave unset to use embedded PGlite
# (Postgres-in-WASM, no server required) for the "sql" persistence backend.
DATABASE_URL=

# Figma live mode (token-optional; unset = built-in mock board).
# Personal access token + the file key of your campaign board template.
FIGMA_TOKEN=
FIGMA_FILE_KEY=

# Claude Design (Anthropic Labs) via its MCP server (token-optional).
# Defaults to https://api.anthropic.com/v1/design/mcp when the URL is unset.
CLAUDE_DESIGN_TOKEN=
CLAUDE_DESIGN_MCP_URL=

# Microsoft Teams (token-optional; unset = in-app notification feed only).
# Workflows/incoming-webhook URL for channel notifications, and the shared
# secret used to HMAC-verify inbound intake messages (POST /api/inbound/teams).
TEAMS_WEBHOOK_URL=
TEAMS_OUTGOING_SECRET=
